    "prompt": "Write a Python function reverse_words(text) that reverses word order while keeping each word unchanged.",
    "function_name": "reverse_words",
    "tests": [
      "assert reverse_words('one two three') == 'three two one'",
      "assert reverse_words('solo') == 'solo'",
      "assert reverse_words('  spaced   words ') == 'words spaced'"
    ]
  },
  {
