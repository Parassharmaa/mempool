    "function_name": "normalize_records",
    "tests": [
      "records = [{' Name ': ' Ada ', 'AGE': 37}]",
      "assert normalize_records(records) == [{' name ': 'Ada', 'age': 37}]",
      "assert normalize_records([{'X': ' y '}]) == [{'x': 'y'}]"
    ]
  },
  {
    "id": "smoke-top-k-frequent",
    "family": "code_data",
    "prompt": "Write a Python function top_k_frequent(items, k) that returns the k most frequent items, sorted by descending count then item.",
    "function_name": "top_k_frequent",
    "tests": [
      "assert top_k_frequent(['b', 'a', 'b', 'c', 'a', 'b'], 2) == ['b', 'a']",
      "assert top_k_frequent([3, 3, 2, 2, 1], 2) == [2, 3]",
      "assert top_k_frequent([], 3) == []"
    ]
  },
  {
    "id": "smoke-flatten-list",
    "family": "code_data",
    "prompt": "Write a Python function flatten_once(items) that flattens one level of nested lists while preserving order.",
    "function_name": "flatten_once",
    "tests": [
      "assert flatten_once([1, [2, 3], 4]) == [1, 2, 3, 4]",
      "assert flatten_once([[1], [], [2, 3]]) == [1, 2, 3]",
      "assert flatten_once(['a', ['b']]) == ['a', 'b']"
    ]
  },
  {
