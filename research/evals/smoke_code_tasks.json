  {
    "id": "smoke-group-by-key",
    "family": "code_data",
    "prompt": "Write a Python function group_by_key(records, key) that groups a list of dicts by the given key value.",
    "function_name": "group_by_key",
    "tests": [
      "records = [{'team': 'a', 'n': 1}, {'team': 'b', 'n': 2}, {'team': 'a', 'n': 3}]",
      "assert group_by_key(records, 'team') == {'a': [records[0], records[2]], 'b': [records[1]]}",
      "assert group_by_key([{'x': 1}, {'y': 2}], 'x') == {1: [{'x': 1}], None: [{'y': 2}]}"
    ]
  },
